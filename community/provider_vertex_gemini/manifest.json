{
  "name": "provider-vertex-gemini",
  "version": "0.1.0",
  "description": "Vertex AI Gemini LLM provider via pydantic-ai",
  "schema_version": "1.0.0",
  "language": "python",
  "capabilities": ["model_provider:register"],
  "dependencies": ["pydantic-ai>=0.0.1"],
  "config_schema": {
    "project": {
      "type": "string",
      "required": true,
      "env": "GCP_PROJECT",
      "description": "Google Cloud project ID"
    },
    "location": {
      "type": "string",
      "default": "us-central1",
      "env": "GCP_LOCATION",
      "description": "Vertex AI region"
    },
    "model": {
      "type": "string",
      "default": "gemini-2.0-flash",
      "env": "VERTEX_GEMINI_MODEL",
      "description": "Gemini model to use"
    }
  },
  "hooks_subscribed": {},
  "events_subscribed": [],
  "transport": {
    "type": "in-process",
    "entry_point": "provider_vertex_gemini:VertexGeminiProviderPlugin"
  }
}
