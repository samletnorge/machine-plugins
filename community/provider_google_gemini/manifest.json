{
  "name": "provider_google_gemini",
  "version": "0.1.0",
  "description": "Google Gemini LLM provider via pydantic-ai",
  "schema_version": "1.0.0",
  "language": "python",
  "capabilities": ["model_provider:register"],
  "dependencies": ["pydantic-ai>=0.0.1"],
  "config_schema": {
    "api_key": {
      "type": "string",
      "secret": true,
      "required": true,
      "env": "GCP_API_KEY",
      "description": "Google Cloud API key"
    },
    "model": {
      "type": "string",
      "default": "gemini-2.0-flash",
      "env": "GOOGLE_GEMINI_MODEL",
      "description": "Default model to use"
    }
  },
  "hooks_subscribed": {},
  "events_subscribed": [],
  "transport": {
    "type": "in-process",
    "entry_point": "provider_google_gemini:GoogleGeminiProviderPlugin"
  }
}
