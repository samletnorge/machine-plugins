[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "A machine-core AI agent project"
requires-python = ">=3.12"
dependencies = [
    "machine-core @ git+ssh://git@github.com/samletnorge/machine-core.git",
    "machine-core-server-support @ git+ssh://git@github.com/samletnorge/machine-plugins.git#subdirectory=framework/server_support",
    "machine-core-agent-support @ git+ssh://git@github.com/samletnorge/machine-plugins.git#subdirectory=framework/agent_support",
    "machine-core-tool-support @ git+ssh://git@github.com/samletnorge/machine-plugins.git#subdirectory=framework/tool_support",
]

[tool.machine-core]
entry = "src.main:machine"
plugins = ["machine_agent", "machine_tool", "machine_server"]

[tool.hatch.metadata]
allow-direct-references = true

[tool.hatch.build.targets.wheel]
packages = ["src"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
