[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "A machine-core AI agent project"
requires-python = ">=3.12"
dependencies = [
    "machine-core @ git+ssh://git@github.com/samletnorge/machine-core.git",
]

[tool.machine-core]
entry = "src.main:machine"

[tool.hatch.metadata]
allow-direct-references = true

[tool.hatch.build.targets.wheel]
packages = ["src"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
