[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "A machine-core AI agent project"
requires-python = ">=3.12"
dependencies = [
    "server_support",
]

[tool.uv.sources]
server_support = { git = "git+ssh://git@github.com/samletnorge/machine-plugins.git", subdirectory = "framework/server_support" }


[tool.uv]
default-groups = "all"

[tool.machine-core]
entry = "src.main:machine"
plugins = [
    "tool_support",
    "model_provider_support",
    "agent_support",  
    "server_support",
    "provider_ollama",
    "embeddings",
    "embeddings_ollama",
    "vectorstore_support",
    "vectorstore_lancedb",
    "eval_support",
    "tool_openapi",
    "tool_filter_rag",
    "rag_support",
    "agent_runtime_pydantic",
    "agent_runtime_basic",
]

# Per-plugin configuration (overrides manifest defaults & env vars)
[tool.machine-core.plugin_configs.provider-ollama]
base_url = "http://localhost:9012"
model = "gemma4:latest"

[tool.machine-core.plugin_configs.eval-support]
judge_llm = { provider = "ollama", model = "gemma4:latest" }

[tool.machine-core.plugin_configs.rag-support]
reranker_llm = { provider = "ollama", model = "gemma4:latest" }
extractor_llm = { provider = "ollama", model = "gemma4:latest" }

[tool.hatch.metadata]
allow-direct-references = true

[tool.hatch.build.targets.wheel]
packages = ["src"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
